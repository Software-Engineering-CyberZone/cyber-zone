@model MVC.Models.LoginViewModel
@{
    ViewData["Title"] = "Увійти";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CyberZone</title>
    
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    
    <style>
        .forgot-password-container {
            text-align: right;
            margin-top: -10px; /* Підтягуємо ближче до поля паролю */
            margin-bottom: 30px; /* Відштовхуємо кнопку логіну вниз */
        }
        
        .forgot-password-link {
            font-family: 'Lato', sans-serif;
            font-weight: 500;
            font-size: 14px;
            color: var(--text-light);
            text-decoration: underline;
        }
        
        .forgot-password-link:hover {
            color: #D6FF3F; /* Лаймовий колір при наведенні */
        }
    </style>
</head>
<body class="cyber-auth">

    <header class="cyber-header">
        <div class="header-left">
            <img src="~/images/logo.png" alt="Logo" class="logo-img" /> 
            <span class="logo-text">CyberZone</span>
        </div>
        <div class="header-right">
            <div class="avatar-circle"></div>
            <span class="guest-text">Гість</span>
        </div>
    </header>

    <main class="auth-wrapper">
        <div class="auth-card" style="height: auto; min-height: 479px;">
            
            <h1 class="auth-title">Вітаємо!</h1>
            <div asp-validation-summary="ModelOnly" class="text-danger" style="color: #ff4d4d; font-size: 14px; margin-bottom: 15px; text-align: center;"></div>
            <form asp-controller="Account" asp-action="Login" method="post" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                
                <div class="form-group">
                    <label class="auth-label" asp-for="Email">Email</label>
                    <input type="email" class="auth-input" asp-for="Email" placeholder="your@email.com" />
                    <span asp-validation-for="Email" class="text-danger" style="color: #ff4d4d; font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group" style="margin-bottom: 12px;">
                    <label class="auth-label" asp-for="Password">Пароль</label>
                    <input type="password" class="auth-input" asp-for="Password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger" style="color: #ff4d4d; font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="forgot-password-container">
                    <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-password-link">Забули пароль?</a>
                </div>

                <button type="submit" class="auth-btn btn-register" style="margin-top: 0;">Увійти</button>
                
                <a asp-controller="Home" asp-action="Index" class="auth-btn btn-cancel">Скасувати</a>

            </form>

            <div class="auth-footer-text">
                Не маєте акаунту? <a asp-controller="Account" asp-action="Register" class="auth-link">Зареєструватися</a>
            </div>

        </div>
    </main>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>