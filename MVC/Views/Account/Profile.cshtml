@using CyberZone.Application.DTOs
@model UserProfileDto

@{
    ViewData["Title"] = "Особистий кабінет";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    
    <style>
        html, body {
            overflow: hidden !important;
        }

        main.pb-3 {
            padding-bottom: 0 !important;
        }
        
        .container {
            max-width: 100% !important;
            padding: 0 !important;
        }
    </style>
}

<div class="profile-container">
    <div class="profile-card">
        
        <div class="profile-header-info">
            <div class="profile-avatar-large">
                </div>
            
            <div class="profile-details">
                <h2 class="profile-name">@Model.UserName</h2>
                <p class="profile-email">
                    <svg class="email-icon" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20 4H4C2.9 4 2.01 4.9 2.01 6L2 18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4ZM20 8L12 13L4 8V6L12 11L20 6V8Z"/>
                    </svg>
                    @Model.Email
                </p>
                <div class="profile-balance-row">
                    <span class="balance-label">Баланс:</span>
                    <span class="balance-amount">@Model.Balance.ToString("N0") ₴</span>
                </div>
            </div>

            <button class="btn-edit-profile">Редагувати</button>
        </div>

        <hr class="divider" />

        <div class="profile-menu">
            <a asp-controller="Account" asp-action="Balance" class="menu-item" style="text-decoration: none;">
                <span class="menu-text">Баланс</span>
                <div class="menu-arrow"></div>
            </a>
            <hr class="divider divider-short" />
            
            <a asp-controller="Account" asp-action="Sessions" class="menu-item" style="text-decoration: none;">
                <span class="menu-text">Сесії</span>
                <div class="menu-arrow"></div>
            </a>
            <hr class="divider divider-short" />
        </div>

        <div class="profile-actions">
            <a asp-controller="Home" asp-action="Catalog" class="btn-profile-action btn-to-clubs">
                До клубів
            </a>
            
            <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form-profile">
                <button type="submit" class="btn-profile-action btn-logout-large">
                    Вийти з акаунту
                </button>
            </form>
        </div>

    </div>
</div>