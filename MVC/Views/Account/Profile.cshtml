@using CyberZone.Application.DTOs
@model UserProfileDto

@{
    ViewData["Title"] = "Особистий кабінет";
}

<div class="container" style="padding-top: 100px; padding-bottom: 60px;">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <!-- Основна картка профілю -->
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h3 class="mb-0">Мій профіль</h3>
                </div>
                
                <div class="card-body p-4 bg-dark text-white">
                    
                    <!-- Блок користувача -->
                    <div class="text-center mb-4">
                        <!-- Аватарка заглушка -->
                        <div style="width: 80px; height: 80px; background-color: #6c757d; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: bold; margin: 0 auto;">
                            @Model.UserName?.Substring(0, 1).ToUpper()
                        </div>
                        
                        <h2 class="mt-3">@Model.UserName</h2>
                        <p class="text-muted">@Model.Email</p>
                    </div>

                    <hr class="border-secondary" />

                    <!-- Блок балансу -->
                    <div class="d-flex justify-content-between align-items-center mb-4 px-3 py-2" style="background-color: rgba(255,255,255,0.05); border-radius: 8px;">
                        <span class="fs-5">Ваш баланс:</span>
                        <span class="fs-3 fw-bold text-success">@Model.Balance.ToString("N0") ₴</span>
                    </div>

                    <!-- Кнопки дій -->
                    <div class="d-grid gap-3">
                        <a asp-controller="Home" asp-action="Catalog" class="btn btn-primary btn-lg">
                            Перейти до списку клубів
                        </a>
                        
                        <!-- Заглушки для майбутнього функціоналу -->
                        <button type="button" class="btn btn-outline-light" disabled>
                            Історія бронювань (скоро)
                        </button>
                    </div>
                </div>

                <div class="card-footer bg-dark border-secondary p-3">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-grid">
                        <button type="submit" class="btn btn-danger">
                            Вийти з акаунту
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>