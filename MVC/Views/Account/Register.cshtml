@model MVC.Models.RegisterViewModel
@{
    ViewData["Title"] = "Реєстрація";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CyberZone</title>
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="cyber-auth">

    <header class="cyber-header">
        <div class="header-left">
            <img src="~/images/logo.png" alt="Logo" class="logo-img" /> 
            <span class="logo-text">CyberZone</span>
        </div>
        <div class="header-right">
            <div class="avatar-circle"></div>
            <span class="guest-text">Гість</span>
        </div>
    </header>

    <main class="auth-wrapper">
        <div class="auth-card">
            
            <h1 class="auth-title">Раді з Вами познайомитись!</h1>
            <div asp-validation-summary="ModelOnly" class="text-danger" style="color: #ff4d4d; font-size: 14px; margin-bottom: 15px; text-align: center;"></div>
            <form asp-controller="Account" asp-action="Register" method="post">
                
                <div class="form-group">
                    <label class="auth-label" asp-for="UserName">Нікнейм (Логін)</label>
                    <input type="text" class="auth-input" asp-for="UserName" placeholder="cyber_gamer99" />
                    <span asp-validation-for="UserName" class="text-danger" style="color: #ff4d4d; font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label class="auth-label" asp-for="FullName">Ім’я</label>
                    <input type="text" class="auth-input" asp-for="FullName" placeholder="Введіть ваше ім'я" />
                    <span asp-validation-for="FullName" class="text-danger" style="color: #ff4d4d; font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label class="auth-label" asp-for="Email">Email</label>
                    <input type="email" class="auth-input" asp-for="Email" placeholder="your@email.com" />
                    <span asp-validation-for="Email" class="text-danger" style="color: #ff4d4d; font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label class="auth-label" asp-for="Password">Пароль</label>
                    <input type="password" class="auth-input" asp-for="Password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger" style="color: #ff4d4d; font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <div class="form-group">
                    <label class="auth-label" asp-for="ConfirmPassword">Підтвердження паролю</label>
                    <input type="password" class="auth-input" asp-for="ConfirmPassword" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="color: #ff4d4d; font-size: 12px; display: block; margin-top: 4px;"></span>
                </div>

                <button type="submit" class="auth-btn btn-register">Зареєструватися</button>
                
                <a asp-controller="Home" asp-action="Index" class="auth-btn btn-cancel">Скасувати</a>

            </form>

            <div class="auth-footer-text">
                Вже маєте акаунт? <a asp-controller="Account" asp-action="Login" class="auth-link">Увійти</a>
            </div>

        </div>
    </main>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>