@using MVC.Models
@model TopUpViewModel

@{
    ViewData["Title"] = "Поповнення балансу";
}

@section Styles {
    <style>
        body {
            background-color: #0B1222;
            color: #EDEDED;
        }
        .topup-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: calc(100vh - 120px);
            padding: 40px 20px;
        }
        .topup-card {
            background: #0C1420;
            border-radius: 10px;
            width: 100%;
            max-width: 450px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .topup-title {
            color: #EDEDED;
            font-family: 'Lato', sans-serif;
            font-size: 24px;
            margin-bottom: 30px;
            text-align: center;
        }
        .form-group { margin-bottom: 20px; }
        .form-label {
            color: #93A0A9;
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            margin-bottom: 8px;
            display: block;
        }
        .form-control-cyber {
            width: 100%;
            height: 45px;
            background: #1B2735;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 5px;
            padding: 0 15px;
            color: #EDEDED;
            font-family: 'Inter', sans-serif;
            font-size: 16px;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-control-cyber:focus { border-color: #D6FF3F; }
        .row-split { display: flex; gap: 15px; }
        .row-split .form-group { flex: 1; }
        
        .btn-submit-payment {
            width: 100%;
            height: 50px;
            background: linear-gradient(91.95deg, #D6FF3F 2.89%, #E05BBE 97.05%);
            border-radius: 5px;
            border: none;
            font-family: 'Inter', sans-serif;
            font-weight: 500;
            font-size: 16px;
            color: #1C2838;
            cursor: pointer;
            margin-top: 15px;
            transition: opacity 0.2s;
        }
        .btn-submit-payment:hover { opacity: 0.9; }
        .text-danger { color: #ff4d4d; font-size: 12px; margin-top: 5px; display: block; }
        .test-card-hint {
            margin-top: 20px;
            padding: 15px;
            background: rgba(255,255,255,0.02);
            border-radius: 5px;
            font-size: 12px;
            color: #93A0A9;
            text-align: center;
        }
    </style>
}

<div class="topup-container">
    <div class="topup-card">
        <h2 class="topup-title">Поповнення балансу</h2>

        <form asp-action="TopUp" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 15px;"></div>

            <div class="form-group">
                <label class="form-label">Сума поповнення (₴)</label>
                <input asp-for="Amount" class="form-control-cyber" placeholder="Наприклад: 500" type="number" step="1" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Номер картки</label>
                <input asp-for="CardNumber" class="form-control-cyber" placeholder="0000 0000 0000 0000" maxlength="16" />
                <span asp-validation-for="CardNumber" class="text-danger"></span>
            </div>

            <div class="row-split">
                <div class="form-group">
                    <label class="form-label">Термін дії</label>
                    <input asp-for="ExpiryDate" class="form-control-cyber" placeholder="MM/YY" maxlength="5" />
                    <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">CVV</label>
                    <input asp-for="Cvv" class="form-control-cyber" type="password" placeholder="•••" maxlength="3" />
                    <span asp-validation-for="Cvv" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn-submit-payment">Оплатити</button>
        </form>

        <div class="test-card-hint">
            <strong>Тестовий режим:</strong><br/>
            Використовуйте картку: 4111111111111111<br/>
            CVV: 123 | Дата: будь-яка майбутня
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}