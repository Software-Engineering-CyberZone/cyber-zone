@model IEnumerable<CyberZone.Application.DTOs.BarMenuItemDto>
@{
    ViewData["Title"] = "Меню Бару";
}

<style>
    body {
        background-color: #0B1222;
        color: #EDEDED;
        font-family: 'Lato', sans-serif;
    }
    .bar-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 20px;
    }
    .cyber-top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }
    .cyber-btn-primary {
        background: linear-gradient(91.95deg, #D6FF3F 2.89%, #E05BBE 97.05%);
        color: #0B1222;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        font-weight: 500;
        text-decoration: none;
        transition: opacity 0.2s;
    }
    .cyber-btn-primary:hover {
        opacity: 0.9;
        color: #0B1222;
        text-decoration: none;
    }
    .cyber-panel {
        background: #1C2838;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #93A0A9;
    }
    .cyber-table {
        width: 100%;
        color: #EDEDED;
        border-collapse: collapse;
    }
    .cyber-table th {
        text-align: left;
        padding: 15px 10px;
        color: #93A0A9;
        font-weight: 500;
        border-bottom: 1px solid #2A3B52;
    }
    .cyber-table td {
        padding: 15px 10px;
        border-bottom: 1px solid #2A3B52;
        vertical-align: middle;
    }
    .cyber-input {
        background: #0C1420;
        border: 1px solid #2A3B52;
        color: #EDEDED;
        border-radius: 6px;
        padding: 8px 12px;
        outline: none;
    }
    .cyber-input:focus {
        border-color: #D6FF3F;
    }
    .cyber-btn-sm {
        background: #2A3B52;
        color: #EDEDED;
        border: none;
        padding: 8px 15px;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .cyber-btn-sm:hover {
        background: #93A0A9;
        color: #0B1222;
    }
    .danger-row td {
        background-color: rgba(224, 91, 190, 0.1) !important;
    }
</style>

<div class="bar-container">
    <div class="cyber-top-bar">
        <h2 style="margin: 0;">@ViewData["Title"]</h2>
        <a asp-action="Create" class="cyber-btn-primary">+ Додати позицію</a>
    </div>

    <div class="cyber-panel">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th>Назва</th>
                    <th>Категорія</th>
                    <th>Ціна</th>
                    <th>Залишок</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.StockQuantity < 5 ? "danger-row" : "")">
                        <td><strong>@item.Name</strong></td>
                        <td>
                            @if (item.Category == "Снеки")
                            {
                                <text>🍔 Снеки</text>
                            }
                            else if (item.Category == "Напої")
                            {
                                <text>🥤 Напої</text>
                            }
                            else
                            {
                                @item.Category
                            }
                        </td>
                        <td>₴@item.Price.ToString("F2")</td>
                        <td>
                            <form asp-action="UpdateStock" method="post" style="display: flex; align-items: center; gap: 10px; margin: 0;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="number" name="stockQuantity" value="@item.StockQuantity" class="cyber-input" min="0" style="width: 80px;" />
                                <button type="submit" class="cyber-btn-sm">Ок</button>
                            </form>
                        </td>
                        <td>
                            <form asp-action="ToggleActive" method="post" style="margin: 0;">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="isActive" class="cyber-input" style="width: 140px; cursor: pointer;" onchange="this.form.submit()">
                                    @if (item.IsActive)
                                    {
                                        <option value="true" selected>🟩 Активно</option>
                                        <option value="false">⬛ Приховано</option>
                                    }
                                    else
                                    {
                                        <option value="true">🟩 Активно</option>
                                        <option value="false" selected>⬛ Приховано</option>
                                    }
                                </select>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
