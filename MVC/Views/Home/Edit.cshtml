@model CyberZone.Application.DTOs.EditClubDto

@{
    ViewData["Title"] = "Редагування клубу";
}

<style>
    .edit-club-wrapper {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 60px;
        padding-bottom: 60px;
        width: 100%;
        color: #ffffff;
    }

    .edit-club-card {
        background-color: #1a1a1a;
        width: 100%;
        max-width: 600px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        border: 1px solid #333;
        padding: 30px;
    }

    .edit-club-header {
        text-align: center;
        margin-bottom: 25px;
    }

    .edit-club-header h2 {
        font-weight: 700;
        margin-bottom: 5px;
        font-size: 24px;
        background: linear-gradient(91.95deg, #D6FF3F 2.89%, #E05BBE 97.05%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .cz-form-group {
        margin-bottom: 20px;
    }

    .cz-form-group label {
        display: block;
        margin-bottom: 8px;
        color: #aaa;
        font-size: 14px;
    }

    .cz-form-control {
        width: 100%;
        padding: 12px 15px;
        border-radius: 8px;
        border: 1px solid #333;
        background-color: #0B1222;
        color: #ffffff;
        font-size: 15px;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .cz-form-control:focus {
        outline: none;
        border-color: #D6FF3F;
        box-shadow: 0 0 0 2px rgba(214, 255, 63, 0.2);
    }

    .cz-btn-submit {
        width: 100%;
        padding: 14px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        text-align: center;
        background: linear-gradient(91.95deg, #D6FF3F 2.89%, #E05BBE 97.05%);
        color: #1C2838;
        transition: opacity 0.2s, transform 0.1s;
        margin-top: 10px;
    }

    .cz-btn-submit:hover {
        opacity: 0.9;
    }
    
    .cz-btn-submit:active {
        transform: scale(0.98);
    }

    .cz-btn-cancel {
        display: block;
        width: 100%;
        padding: 14px;
        border-radius: 8px;
        border: 1px solid #444;
        background-color: transparent;
        color: #fff;
        text-align: center;
        font-weight: 600;
        text-decoration: none;
        margin-top: 15px;
        transition: background-color 0.2s;
    }

    .cz-btn-cancel:hover {
        background-color: rgba(255,255,255,0.05);
        color: #fff;
    }

    .text-danger {
        color: #dc3545;
        font-size: 13px;
        margin-top: 5px;
        display: block;
    }
</style>

<div class="edit-club-wrapper">
    <div class="edit-club-card">
        <div class="edit-club-header">
            <h2>Редагування клубу</h2>
            <p style="color: #888;">Змініть контактні дані та адресу нижче</p>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="cz-form-group">
                <label asp-for="Name">Назва клубу</label>
                <input asp-for="Name" class="cz-form-control" placeholder="Введіть назву" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="cz-form-group">
                <label asp-for="Description">Опис</label>
                <textarea asp-for="Description" class="cz-form-control" rows="4" placeholder="Опишіть ваш клуб..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 cz-form-group">
                    <label asp-for="Phone">Телефон</label>
                    <input asp-for="Phone" class="cz-form-control" placeholder="+380..." />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-6 cz-form-group">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" class="cz-form-control" placeholder="example@mail.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <h5 style="margin-top: 20px; margin-bottom: 15px; color: #fff; border-bottom: 1px solid #333; padding-bottom: 10px;">Адреса</h5>

            <div class="row">
                <div class="col-md-6 cz-form-group">
                    <label asp-for="Country">Країна</label>
                    <input asp-for="Country" class="cz-form-control" />
                    <span asp-validation-for="Country" class="text-danger"></span>
                </div>
                <div class="col-md-6 cz-form-group">
                    <label asp-for="State">Область / Регіон</label>
                    <input asp-for="State" class="cz-form-control" />
                    <span asp-validation-for="State" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-8 cz-form-group">
                    <label asp-for="City">Місто</label>
                    <input asp-for="City" class="cz-form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
                <div class="col-md-4 cz-form-group">
                    <label asp-for="ZipCode">Індекс</label>
                    <input asp-for="ZipCode" class="cz-form-control" />
                    <span asp-validation-for="ZipCode" class="text-danger"></span>
                </div>
            </div>

            <div class="cz-form-group">
                <label asp-for="Street">Вулиця (та номер будинку)</label>
                <input asp-for="Street" class="cz-form-control" />
                <span asp-validation-for="Street" class="text-danger"></span>
            </div>

            <h5 style="margin-top: 20px; margin-bottom: 15px; color: #fff; border-bottom: 1px solid #333; padding-bottom: 10px;">Графік роботи</h5>
            <div class="row">
                @{
                    var days = new[] { "Понеділок", "Вівторок", "Середа", "Четвер", "П'ятниця", "Субота", "Неділя" };
                    foreach (var day in days)
                    {
                        var val = Model.WorkHours != null && Model.WorkHours.ContainsKey(day) ? Model.WorkHours[day] : "";
                        <div class="col-md-6 cz-form-group">
                            <label>@day</label>
                            <input type="text" name="WorkHours[@day]" value="@val" class="cz-form-control" placeholder="09:00 - 23:00" />
                        </div>
                    }
                }
            </div>

            <button type="submit" class="cz-btn-submit">Зберегти зміни</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="cz-btn-cancel">Скасувати</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}