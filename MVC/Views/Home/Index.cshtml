@{
    ViewData["Title"] = "Welcome";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CyberZone</title>
    <link rel="stylesheet" href="~/css/welcome.css" asp-append-version="true" />
</head>
<body class="cyber-welcome">

    <header class="cyber-header">
        <div class="header-left">
            <img src="~/images/logo.png" alt="Logo" class="logo-img" /> 
            <span class="logo-text">CyberZone</span>
        </div>
        
        <div class="header-right">
            <div class="avatar-circle"></div>
            <span class="guest-text">Гість</span>
        </div>
    </header>

    <main class="main-container">
        
        <img src="~/images/welcome_gaming.png" alt="Hero Image" class="hero-image" />

        <div class="content-split">
            
            <div class="text-section">
                <h1 class="hero-title">Ми тут, щоб допомогти тобі відпочити!</h1>
                <p class="hero-desc">
                    Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.
                </p>
            </div>

            <div class="actions-section">
                <a asp-controller="Home" asp-action="Catalog" class="btn-cyber btn-dark">Переглянути каталог</a>
                
                <a asp-controller="Account" asp-action="Login" class="btn-cyber btn-dark">Увійти</a>
                
                <a asp-controller="Account" asp-action="Register" class="btn-cyber btn-gradient">Зареєструватися</a>
                
                <a asp-controller="Account" asp-action="ClubPartner" class="btn-cyber btn-style-4">Для власника клубу</a>
            </div>

        </div>
    </main>

</body>
</html>