@using CyberZone.Application.DTOs
@model IReadOnlyList<GameDealDto>

@if (Model.Count > 0)
{
    <div class="deals-widget">
        <div class="deals-widget-title">
            🔥 Гарячі знижки
            <a asp-controller="Deals" asp-action="Index">усі →</a>
        </div>
        <div class="deals-widget-list">
            @foreach (var d in Model)
            {
                <a href="@d.DealUrl" target="_blank" rel="noopener noreferrer" class="deals-widget-row">
                    @if (!string.IsNullOrEmpty(d.ThumbnailUrl))
                    {
                        <img src="@d.ThumbnailUrl" alt="@d.Title" class="deals-widget-thumb" loading="lazy" />
                    }
                    <div class="deals-widget-info">
                        <div class="deals-widget-name">@d.Title</div>
                        <div class="deals-widget-prices">
                            <span class="deals-widget-sale">$@d.SalePrice.ToString("0.00")</span>
                            @if (d.NormalPrice > d.SalePrice)
                            {
                                <span style="text-decoration: line-through;">$@d.NormalPrice.ToString("0.00")</span>
                            }
                        </div>
                    </div>
                    @if (d.SavingsPercent > 0)
                    {
                        <span class="deals-widget-badge">-@d.SavingsPercent.ToString("0")%</span>
                    }
                </a>
            }
        </div>
    </div>
}
